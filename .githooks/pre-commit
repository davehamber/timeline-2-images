#!/usr/bin/env bash
# Pre-commit hook: Validate version consistency across files

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Extract version from each file
get_version_from_init() {
    grep -oP '__version__ = "\K[^"]+' "$PROJECT_ROOT/src/timeline_2_images/__init__.py" 2>/dev/null || echo ""
}

get_version_from_pyproject() {
    grep -oP '^version = "\K[^"]+' "$PROJECT_ROOT/pyproject.toml" 2>/dev/null || echo ""
}

get_version_from_bumpversion() {
    grep -oP 'current_version = \K[0-9.]+' "$PROJECT_ROOT/.bumpversion.cfg" 2>/dev/null || echo ""
}

VERSION_INIT=$(get_version_from_init)
VERSION_PYPROJECT=$(get_version_from_pyproject)
VERSION_BUMPVERSION=$(get_version_from_bumpversion)

# Check if all versions match
if [[ "$VERSION_INIT" != "$VERSION_PYPROJECT" ]] || [[ "$VERSION_INIT" != "$VERSION_BUMPVERSION" ]]; then
    echo -e "${RED}❌ Version mismatch detected!${NC}"
    echo ""
    echo "Versions found:"
    echo -e "  ${YELLOW}__init__.py${NC}:       $VERSION_INIT"
    echo -e "  ${YELLOW}pyproject.toml${NC}:    $VERSION_PYPROJECT"
    echo -e "  ${YELLOW}.bumpversion.cfg${NC}: $VERSION_BUMPVERSION"
    echo ""
    echo "To fix this:"
    echo "  1. If you ran 'bump2version' partially, complete it or undo with:"
    echo "     git reset --hard HEAD~1"
    echo "  2. If you manually edited files, ensure all three have the same version"
    echo ""
    exit 1
fi

# Check if staged changes include version files but .bumpversion.cfg wasn't updated
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || echo "")

if echo "$STAGED_FILES" | grep -qE "(src/timeline_2_images/__init__.py|pyproject.toml)" && \
   ! echo "$STAGED_FILES" | grep -q ".bumpversion.cfg"; then
    echo -e "${YELLOW}⚠️  Warning: Version files modified but .bumpversion.cfg not staged${NC}"
    echo "If you're using 'bump2version', this is unexpected."
    echo "If you're manually bumping, don't forget to update .bumpversion.cfg"
    echo ""
fi

echo -e "${GREEN}✓ Version consistency check passed${NC} (v${VERSION_INIT})"
echo ""

# ============================================================================
# RUFF: Code Quality Checks
# ============================================================================

echo -e "${YELLOW}Running code quality checks...${NC}"
echo ""

# Run ruff linting on staged files
RUFF_LINT_RESULT=0
echo -e "${CYAN}→ Linting with ruff...${NC}"
if uv run ruff check src/ tests/ --exit-zero 2>&1 | grep -q "Found"; then
    echo -e "${YELLOW}⚠️  Linting issues found (non-blocking):${NC}"
    uv run ruff check src/ tests/ 2>&1 | grep -E "^[A-Z][0-9]+" | head -10
    echo "  (Run 'uv run ruff check src/ tests/' to see all issues)"
    echo "  (Run 'uv run ruff check --fix src/ tests/' to auto-fix)"
    RUFF_LINT_RESULT=0  # Don't block commit for lint issues
else
    echo -e "${GREEN}✓ No linting issues${NC}"
fi
echo ""

# Run ruff format check on staged files
RUFF_FORMAT_RESULT=0
echo -e "${CYAN}→ Checking code formatting...${NC}"
if uv run ruff format src/ tests/ --check 2>&1 | grep -q "would be reformatted"; then
    echo -e "${YELLOW}⚠️  Formatting issues found (non-blocking):${NC}"
    uv run ruff format src/ tests/ --check 2>&1 | grep "Would reformat"
    echo "  (Run 'uv run ruff format src/ tests/' to auto-fix)"
    RUFF_FORMAT_RESULT=0  # Don't block commit for format issues
else
    echo -e "${GREEN}✓ Code formatting is correct${NC}"
fi
echo ""

echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
exit 0
