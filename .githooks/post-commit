#!/usr/bin/env bash
# Post-commit hook: Suggest version bump if there are unreleased changes

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Colors for output
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Check if CHANGELOG has unreleased changes
if ! grep -q "^## \[Unreleased\]$" "$PROJECT_ROOT/CHANGELOG.md"; then
    exit 0
fi

# Count unreleased entries (lines between [Unreleased] and next version header)
UNRELEASED_CONTENT=$(sed -n '/^## \[Unreleased\]$/,/^## \[/p' "$PROJECT_ROOT/CHANGELOG.md" | sed '1d;$d')

if [ -z "$UNRELEASED_CONTENT" ] || [ "$(echo "$UNRELEASED_CONTENT" | wc -l)" -lt 2 ]; then
    exit 0
fi

# Get current version
CURRENT_VERSION=$(grep -oP '__version__ = "\K[^"]+' "$PROJECT_ROOT/src/timeline_2_images/__init__.py")

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${YELLOW}📝 Unreleased changes in CHANGELOG.md${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo "Consider bumping the version when ready for release:"
echo ""
echo -e "  Current version: ${GREEN}${CURRENT_VERSION}${NC}"
echo ""
echo -e "  ${CYAN}uv run bump2version patch${NC}   # Bug fixes (${CURRENT_VERSION} → next patch)"
echo -e "  ${CYAN}uv run bump2version minor${NC}   # New features (${CURRENT_VERSION} → next minor)"
echo -e "  ${CYAN}uv run bump2version major${NC}   # Breaking changes (${CURRENT_VERSION} → next major)"
echo ""
echo -e "See ${CYAN}.claude/VERSION_BUMPING_GUIDE.md${NC} for details"
echo ""
